{
  "meta": {
    "version": "0.1.0",
    "schemaVersion": "1.0.0"
  },
  "primitives": {
    "color": {
      "white": { "$value": "#FFFFFF", "$type": "color" },
      "black": { "$value": "#000000", "$type": "color" },
      "neutral": {
        "0": { "$value": "#FFFFFF", "$type": "color" },
        "50": { "$value": "#F8FAFC", "$type": "color" },
        "100": { "$value": "#F1F5F9", "$type": "color" },
        "200": { "$value": "#E2E8F0", "$type": "color" },
        "300": { "$value": "#CBD5E1", "$type": "color" },
        "400": { "$value": "#94A3B8", "$type": "color" },
        "500": { "$value": "#64748B", "$type": "color" },
        "600": { "$value": "#475569", "$type": "color" },
        "700": { "$value": "#334155", "$type": "color" },
        "800": { "$value": "#1E293B", "$type": "color" },
        "900": { "$value": "#0F172A", "$type": "color" },
        "950": { "$value": "#020617", "$type": "color" }
      },
      "blue": {
        "300": { "$value": "#93C5FD", "$type": "color" },
        "400": { "$value": "#60A5FA", "$type": "color" },
        "500": { "$value": "#3B82F6", "$type": "color" },
        "600": { "$value": "#2563EB", "$type": "color" },
        "700": { "$value": "#1D4ED8", "$type": "color" }
      },
      "red": {
        "400": { "$value": "#F87171", "$type": "color" },
        "500": { "$value": "#EF4444", "$type": "color" },
        "600": { "$value": "#DC2626", "$type": "color" }
      },
      "green": {
        "400": { "$value": "#4ADE80", "$type": "color" },
        "500": { "$value": "#22C55E", "$type": "color" },
        "600": { "$value": "#16A34A", "$type": "color" }
      }
    },
    "space": {
      "0": { "$value": "0", "$type": "dimension" },
      "1": { "$value": "4", "$type": "dimension" },
      "2": { "$value": "8", "$type": "dimension" },
      "3": { "$value": "12", "$type": "dimension" },
      "4": { "$value": "16", "$type": "dimension" },
      "5": { "$value": "20", "$type": "dimension" },
      "6": { "$value": "24", "$type": "dimension" },
      "8": { "$value": "32", "$type": "dimension" },
      "10": { "$value": "40", "$type": "dimension" },
      "12": { "$value": "48", "$type": "dimension" }
    },
    "font-size": {
      "xs": { "$value": "12", "$type": "dimension" },
      "sm": { "$value": "14", "$type": "dimension" },
      "md": { "$value": "16", "$type": "dimension" },
      "lg": { "$value": "20", "$type": "dimension" },
      "xl": { "$value": "24", "$type": "dimension" },
      "2xl": { "$value": "32", "$type": "dimension" }
    },
    "line-height": {
      "tight": { "$value": "20", "$type": "dimension", "$description": "px line-height paired with body/sm text so Figma can bind it directly." },
      "body": { "$value": "24", "$type": "dimension", "$description": "px, not a ratio." },
      "heading": { "$value": "40", "$type": "dimension", "$description": "px, not a ratio." }
    },
    "radius": {
      "sm": { "$value": "4", "$type": "dimension" },
      "md": { "$value": "8", "$type": "dimension" },
      "lg": { "$value": "16", "$type": "dimension" },
      "full": { "$value": "9999", "$type": "dimension" }
    }
  },
  "semantic": {
    "color": {
      "action": {
        "primary": {
          "$type": "color",
          "$description": "Primary interactive fill (buttons, key affordances).",
          "$value": {
            "light": { "Mattias": "{primitives.color.blue.600}" },
            "dark": { "Mattias": "{primitives.color.blue.400}" }
          }
        },
        "primary-hover": {
          "$type": "color",
          "$value": {
            "light": { "Mattias": "{primitives.color.blue.700}" },
            "dark": { "Mattias": "{primitives.color.blue.300}" }
          }
        },
        "on-primary": {
          "$type": "color",
          "$description": "Foreground on top of color.action.primary.",
          "$value": {
            "light": { "Mattias": "{primitives.color.white}" },
            "dark": { "Mattias": "{primitives.color.neutral.950}" }
          }
        }
      },
      "text": {
        "default": {
          "$type": "color",
          "$value": {
            "light": { "Mattias": "{primitives.color.neutral.900}" },
            "dark": { "Mattias": "{primitives.color.neutral.50}" }
          }
        },
        "muted": {
          "$type": "color",
          "$value": {
            "light": { "Mattias": "{primitives.color.neutral.500}" },
            "dark": { "Mattias": "{primitives.color.neutral.400}" }
          }
        },
        "inverse": {
          "$type": "color",
          "$value": {
            "light": { "Mattias": "{primitives.color.neutral.50}" },
            "dark": { "Mattias": "{primitives.color.neutral.900}" }
          }
        }
      },
      "background": {
        "default": {
          "$type": "color",
          "$value": {
            "light": { "Mattias": "{primitives.color.neutral.0}" },
            "dark": { "Mattias": "{primitives.color.neutral.950}" }
          }
        },
        "subtle": {
          "$type": "color",
          "$value": {
            "light": { "Mattias": "{primitives.color.neutral.100}" },
            "dark": { "Mattias": "{primitives.color.neutral.800}" }
          }
        }
      },
      "border": {
        "default": {
          "$type": "color",
          "$value": {
            "light": { "Mattias": "{primitives.color.neutral.200}" },
            "dark": { "Mattias": "{primitives.color.neutral.700}" }
          }
        }
      },
      "feedback": {
        "danger": {
          "$type": "color",
          "$value": {
            "light": { "Mattias": "{primitives.color.red.600}" },
            "dark": { "Mattias": "{primitives.color.red.400}" }
          }
        },
        "success": {
          "$type": "color",
          "$value": {
            "light": { "Mattias": "{primitives.color.green.600}" },
            "dark": { "Mattias": "{primitives.color.green.400}" }
          }
        }
      }
    },
    "space": {
      "inset-sm": {
        "$type": "dimension",
        "$value": {
          "light": { "Mattias": "{primitives.space.2}" },
          "dark": { "Mattias": "{primitives.space.2}" }
        }
      },
      "inset-md": {
        "$type": "dimension",
        "$value": {
          "light": { "Mattias": "{primitives.space.4}" },
          "dark": { "Mattias": "{primitives.space.4}" }
        }
      },
      "stack-md": {
        "$type": "dimension",
        "$value": {
          "light": { "Mattias": "{primitives.space.6}" },
          "dark": { "Mattias": "{primitives.space.6}" }
        }
      }
    },
    "radius": {
      "control": {
        "$type": "dimension",
        "$value": {
          "light": { "Mattias": "{primitives.radius.md}" },
          "dark": { "Mattias": "{primitives.radius.md}" }
        }
      },
      "surface": {
        "$type": "dimension",
        "$value": {
          "light": { "Mattias": "{primitives.radius.lg}" },
          "dark": { "Mattias": "{primitives.radius.lg}" }
        }
      }
    },
    "typography": {
      "body-size": {
        "$type": "dimension",
        "$value": {
          "light": { "Mattias": "{primitives.font-size.md}" },
          "dark": { "Mattias": "{primitives.font-size.md}" }
        }
      },
      "body-line-height": {
        "$type": "dimension",
        "$value": {
          "light": { "Mattias": "{primitives.line-height.body}" },
          "dark": { "Mattias": "{primitives.line-height.body}" }
        }
      },
      "heading-size": {
        "$type": "dimension",
        "$value": {
          "light": { "Mattias": "{primitives.font-size.2xl}" },
          "dark": { "Mattias": "{primitives.font-size.2xl}" }
        }
      },
      "heading-line-height": {
        "$type": "dimension",
        "$value": {
          "light": { "Mattias": "{primitives.line-height.heading}" },
          "dark": { "Mattias": "{primitives.line-height.heading}" }
        }
      }
    }
  }
}
